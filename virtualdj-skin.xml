<Skin name="XDJ 480 Hardware" version="8" width="1920" height="480" stretch="yes" ratio="none" no_drag="yes" nbdecks="2" image="2Decks.png">

	<font name="Arial"/>

	<!-- Phase 1.3: Global Variables Initialization -->
	<onload action="set '$show_performance' 1 &amp; set '$show_browser' 0"/>

	<!-- Phase 2: Auxiliary Sidebar Navigation -->
	<panel name="Sidebar">
		<visual>
			<pos x="0" y="0"/>
			<size width="100" height="480"/>
			<off color="#111111" shape="square"/>
		</visual>

		<!-- Performance Button -->
		<visual><pos x="10" y="80"/><size width="80" height="80"/><off color="#222222" shape="square"/></visual>
		<panel visible="var '$show_performance' 1">
			<visual><pos x="10" y="80"/><size width="80" height="80"/><off color="#0055ff" shape="square"/></visual>
		</panel>
		<button action="set '$show_performance' 1 &amp; set '$show_browser' 0">
			<pos x="10" y="80"/>
			<size width="80" height="80"/>
			<text format="PERFORM" align="center" color="#ffffff" size="14" weight="bold" />
		</button>

		<!-- Browser Button -->
		<visual><pos x="10" y="180"/><size width="80" height="80"/><off color="#222222" shape="square"/></visual>
		<panel visible="var '$show_browser' 1">
			<visual><pos x="10" y="180"/><size width="80" height="80"/><off color="#0055ff" shape="square"/></visual>
		</panel>
		<button action="set '$show_performance' 0 &amp; set '$show_browser' 1">
			<pos x="10" y="180"/>
			<size width="80" height="80"/>
			<text format="BROWSE" align="center" color="#ffffff" size="14" weight="bold" />
		</button>

		<!-- System Settings Button -->
		<visual>
			<pos x="10" y="280"/>
			<size width="80" height="80"/>
			<off color="#3a3a3a" shape="square"/>
		</visual>
		<button action="settings">
			<pos x="10" y="280"/>
			<size width="80" height="80"/>
			<text format="SYSTEM" align="center" color="#ffffff" size="14" weight="bold" />
		</button>
	</panel>

	<!-- Phase 3: Main Performance View -->
	<panel name="Performance_View" visible="var '$show_performance' 1">
		<visual>
			<pos x="100" y="0"/>
			<size width="1820" height="380"/>
			<off color="#050505" shape="square"/>
		</visual>

		<!-- Waveforms (Maximized) -->
		<scratchwave deck="left" orientation="horizontal">
			<pos x="100" y="0"/>
			<size width="1820" height="190"/>
			<grid color="#555555" height="10" size="1" mainsize="4" mirrored="true"/>
			<gridlines color="#333333" width="1" transparency="0.5"/>
			<overlay>
				<pos x="1008" y="0"/>
				<size width="4" height="190"/>
				<background color="#ff3333" shape="square"/>
			</overlay>
		</scratchwave>

		<scratchwave deck="right" orientation="horizontal">
			<pos x="100" y="190"/>
			<size width="1820" height="190"/>
			<grid color="#555555" height="10" size="1" mainsize="4" mirrored="true"/>
			<gridlines color="#333333" width="1" transparency="0.5"/>
			<overlay>
				<pos x="1008" y="190"/>
				<size width="4" height="190"/>
				<background color="#ff3333" shape="square"/>
			</overlay>
		</scratchwave>
	</panel>

	<!-- Phase 4: Browser View -->
	<panel name="Browser_View" visible="var '$show_browser' 1">
		<visual>
			<pos x="100" y="0"/>
			<size width="1820" height="380"/>
			<off color="#111111" shape="square"/>
		</visual>
		<browser>
			<pos x="110" y="10"/>
			<size width="1800" height="360"/>
		</browser>
	</panel>


	<!-- Mini-Decks Panel (Always Visible) -->
	<panel name="Mini_Decks">
		<visual>
			<pos x="100" y="380"/>
			<size width="1820" height="100"/>
			<off color="#0a0a0a" shape="square"/>
		</visual>

		<!-- Deck 1 Mini -->
		<deck deck="left">
			<!-- Album Art Left Edge -->
			<cover>
				<pos x="110" y="390"/>
				<size width="80" height="80"/>
			</cover>
			
			<textzone>
				<pos x="200" y="390"/>
				<size width="350" height="40"/>
				<text format="%Title" size="24" color="#ffffff" weight="bold" align="left" scroll="yes"/>
			</textzone>
			<textzone>
				<pos x="560" y="390"/>
				<size width="80" height="40"/>
				<text format="%Pbpmex" size="24" color="#00ffcc" weight="bold" align="left"/>
			</textzone>
			<textzone>
				<pos x="650" y="390"/>
				<size width="80" height="40"/>
				<text format="%key" size="24" color="#00ffcc" align="left"/>
			</textzone>
			<textzone>
				<pos x="740" y="390"/>
				<size width="110" height="40"/>
				<text action="get_time 'remain'" size="28" color="#ffffff" weight="bold" align="right"/>
			</textzone>

			<songpos>
				<pos x="200" y="440"/>
				<size width="650" height="30"/>
				<colors color="#555555" pos="#00ffcc"/>
			</songpos>

			<!-- Contextual Buttons Deck 1 -->
			<panel visible="var '$show_performance' 1">
				<button action="play_pause">
					<pos x="860" y="390"/>
					<size width="60" height="80"/>
					<off color="#222222" shape="square"/>
					<text format="PLAY" size="16" color="#00ff00" weight="bold" align="center"/>
				</button>
				<button action="cue">
					<pos x="930" y="390"/>
					<size width="60" height="80"/>
					<off color="#222222" shape="square"/>
					<text format="CUE" size="16" color="#ffaa00" weight="bold" align="center"/>
				</button>
			</panel>
			<panel visible="var '$show_browser' 1">
				<button action="load">
					<pos x="890" y="390"/>
					<size width="100" height="80"/>
					<off color="#333333" shape="square"/>
					<text format="LOAD 1" size="20" color="#ffffff" weight="bold" align="center"/>
				</button>
			</panel>
		</deck>

		<!-- Deck 2 Mini -->
		<deck deck="right">
			<!-- Contextual Buttons Deck 2 -->
			<panel visible="var '$show_performance' 1">
				<button action="cue">
					<pos x="1030" y="390"/>
					<size width="60" height="80"/>
					<off color="#222222" shape="square"/>
					<text format="CUE" size="16" color="#ffaa00" weight="bold" align="center"/>
				</button>
				<button action="play_pause">
					<pos x="1100" y="390"/>
					<size width="60" height="80"/>
					<off color="#222222" shape="square"/>
					<text format="PLAY" size="16" color="#00ff00" weight="bold" align="center"/>
				</button>
			</panel>
			<panel visible="var '$show_browser' 1">
				<button action="load">
					<pos x="1030" y="390"/>
					<size width="100" height="80"/>
					<off color="#333333" shape="square"/>
					<text format="LOAD 2" size="20" color="#ffffff" weight="bold" align="center"/>
				</button>
			</panel>

			<!-- Mirrored Info -->
			<songpos>
				<pos x="1170" y="440"/>
				<size width="650" height="30"/>
				<colors color="#555555" pos="#00ffcc"/>
			</songpos>
			<textzone>
				<pos x="1170" y="390"/>
				<size width="110" height="40"/>
				<text action="get_time 'remain'" size="28" color="#ffffff" weight="bold" align="left"/>
			</textzone>
			<textzone>
				<pos x="1290" y="390"/>
				<size width="80" height="40"/>
				<text format="%key" size="24" color="#00ffcc" align="right"/>
			</textzone>
			<textzone>
				<pos x="1380" y="390"/>
				<size width="80" height="40"/>
				<text format="%Pbpmex" size="24" color="#00ffcc" weight="bold" align="right"/>
			</textzone>
			<textzone>
				<pos x="1470" y="390"/>
				<size width="350" height="40"/>
				<text format="%Title" size="24" color="#ffffff" weight="bold" align="right" scroll="yes"/>
			</textzone>
			
			<!-- Album Art Right Edge -->
			<cover>
				<pos x="1830" y="390"/>
				<size width="80" height="80"/>
			</cover>
		</deck>
	</panel>

</Skin>